# BulletTrade qmt-remote server configuration for a local Big QMT helper.
# Copy values into the production environment; do not commit real secrets.

QMT_SERVER_TYPE=big_qmt
QMT_SERVER_LISTEN=0.0.0.0
QMT_SERVER_PORT=58620
QMT_SERVER_TOKEN=please_change_me_server_token
# Entity account mapping passed to every helper broker request.
QMT_SERVER_ACCOUNTS=default=please_change_me_account_id:stock
QMT_SERVER_ENABLE_DATA=true
QMT_SERVER_ENABLE_BROKER=true
QMT_SERVER_ACCESS_LOG=true

# Must be longer than BIG_QMT_GATEWAY_TIMEOUT_SECONDS so the outer RPC layer
# does not time out before the helper adapter returns its structured result.
QMT_SERVER_REQUEST_TIMEOUT_SECONDS=150

# This URL normally remains local because the helper runs in Big QMT on the
# same Windows machine as bullet-trade server.
BIG_QMT_GATEWAY_URL=http://127.0.0.1:9000
BIG_QMT_GATEWAY_PASSWORD=please_match_helper_gateway_password

# Set only when helper GATEWAY_SECRET was changed from its placeholder value.
# BIG_QMT_GATEWAY_SECRET=please_match_helper_gateway_secret

# History reads download before every cache read and can be slow. A client-side
# timeout does not cancel a QMT call already running on the helper main thread.
BIG_QMT_GATEWAY_TIMEOUT_SECONDS=120
