# ============================================================
# BulletTrade 环境变量配置示例（通用版本）
# 
# 根据使用场景选择：
#   - 回测：复制 env.backtest.example 为 .env
#   - 实盘：复制 env.live.example 为 .env
#   - 通用：复制本文件 env.example 为 .env
# ============================================================

# ============ 数据源配置 ============
DEFAULT_DATA_PROVIDER=jqdata

# 通用数据缓存目录（各数据源使用 DATA_CACHE_DIR/<provider_name>，留空则禁用磁盘缓存）
DATA_CACHE_DIR=~/.bullet-trade/cache

# JQData (聚宽数据)
JQDATA_USERNAME=your_username
JQDATA_PASSWORD=your_password
JQDATA_SERVER=
JQDATA_PORT=
# 兼容旧变量：如已有 JQDATA_USER/JQDATA_PWD 也可继续使用

# MiniQMT (本地 QMT 行情，需安装 miniQMT/xtquant) 
#QMT_DATA_PATH=C:\国金QMT交易端模拟\userdata_mini       # Windows 默认路径示例
#MINIQMT_AUTO_DOWNLOAD=true                            # 默认开启自动下载；如需只读本地缓存可显式设为 false
#MINIQMT_MARKET=SH                                     # 市场代码：SH=上交所，SZ=深交所

# RQData (米筐数据，需安装 bullet-trade[rqdata] 并配置 license 或账号)
#RQDATA_LICENSE=
#RQDATA_USERNAME=
#RQDATA_PASSWORD=

# easy_tdx (通达信在线行情，需 Python 3.10+ 和 bullet-trade[tdx])
#EASY_TDX_HOST=                                        # 留空时由 easy_tdx 自动选择可用行情服务器
#EASY_TDX_PORT=7709
#EASY_TDX_TIMEOUT=10
#EASY_TDX_USE_STUB=false                               # 仅测试/demo 使用；真实回测不要开启

# ============ 券商配置（实盘） ============
DEFAULT_BROKER=simulator
SIMULATOR_INITIAL_CASH=1000000
#QMT_SESSION_ID=1699942134123                          # 可选：固定 QMT 会话 ID，不填则使用当前时间戳
#QMT_AUTO_SUBSCRIBE=true                               # 可选：connect() 时是否自动订阅账户

# ============ 系统配置 ============
LOG_DIR=./logs
# 控制台日志级别（DEBUG/INFO/WARNING/ERROR）
LOG_LEVEL=INFO
# 文件日志级别（未设置则跟随 LOG_LEVEL）
# LOG_FILE_LEVEL=DEBUG

# ============ 通知配置 ============
# 企业微信机器人 KEY，配置后 send_msg 会推送群机器人
MESSAGE_KEY=

# ============ 回测默认配置 ============
DEFAULT_INITIAL_CASH=100000
DEFAULT_FREQUENCY=daily
DEFAULT_BENCHMARK=000300.XSHG

# ============ 实盘配置 ============
LIVE_MODE=dry_run
MAX_ORDER_VALUE=100000
# 最小买入订单金额，0 表示不限制；仅在实盘/服务端风控开启时生效
MIN_BUY_ORDER_VALUE=0
MAX_DAILY_TRADES=100
MAX_DAILY_CANCELS=100
MIN_CANCEL_INTERVAL_SECONDS=0
MAX_CANCEL_PER_ORDER=3
MAX_STOCK_COUNT=20
# 策略名称（用于实盘订单备注，多策略并行时可区分；未设置时使用策略文件名）
#STRATEGY_NAME=demo-strategy

# ============ 性能优化 ============
USE_UVLOOP=true
ENABLE_CACHE=true
# 单次读取 portfolio 前的最小刷新间隔（毫秒），用于控制实时刷新频率
PORTFOLIO_REFRESH_THROTTLE_MS=200

# 远程 QMT server
QMT_SERVER_HOST=127.0.0.1
QMT_SERVER_PORT=58620
QMT_SERVER_TOKEN=please_change_me
